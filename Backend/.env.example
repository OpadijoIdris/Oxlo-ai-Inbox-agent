# Database Configuration
# Use PostgreSQL for production, SQLite for local development
# PostgreSQL example: postgresql://user:password@localhost:5432/inboxpilot
# SQLite example: file:./dev.db
DATABASE_URL="file:./dev.db"

# JWT Secret Key for token generation
# Use a strong, random string (min 32 characters) for production
JWT_SECRET="your-super-secret-jwt-key-min-32-characters"

# Oxlo.ai API Key
# Get your API key from https://oxlo.ai
# Required for AI message analysis
OXLO_API_KEY="your-oxlo-api-key-here"

# Server Configuration
PORT=5000
NODE_ENV=development

# Optional: API Base URL for CORS
API_URL="http://localhost:5000"
